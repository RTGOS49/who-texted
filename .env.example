PORT=3001

# Backend CORS. In production, set FRONTEND_URL to your Vercel app URL.
FRONTEND_URL=http://localhost:5173
# Optional comma-separated extra origins, useful for Vercel preview URLs.
CORS_ORIGINS=http://127.0.0.1:5173

# Frontend. In production on Vercel, set this to your Render/Railway backend URL.
VITE_SERVER_URL=http://localhost:3001
